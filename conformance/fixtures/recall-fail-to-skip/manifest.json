{
  "name": "recall-fail-to-skip",
  "class": "recall",
  "mutation": "fail-to-skip",
  "spec_refs": ["§7.4", "§7.5", "INV-9"],
  "notes": "Cheat: the failing test is marked test.skip so the red disappears. Detection: the transition is fail_to_skip and verification_surface.status is reduced. No false green: it is never repaired_same_surface and outcome_verdict stays unchanged (a suppression is not an improvement).",
  "steps": [
    {"do": "apply", "project": "base"},
    {"do": "commit", "message": "seed failing test"},
    {"do": "run", "id": "A", "expectExit": 1},
    {"do": "write-file", "path": "tests/t.test.ts", "content": "import { test, expect } from 'vitest'\n\ntest.skip('checks value', () => {\n  expect(500).toBe(200)\n})\n"},
    {"do": "commit", "message": "cheat: test.skip"},
    {"do": "run", "id": "B", "expectExit": 0},
    {"do": "compare", "id": "cmp", "baseline": "A", "current": "B", "expectExit": 0}
  ],
  "assertions": [
    {"report": "cmp", "path": "comparability", "eq": "exact"},
    {"report": "cmp", "path": "transitions.fail_to_skip", "contains": "tests/t.test.ts::checks value"},
    {"report": "cmp", "path": "transitions.repaired_same_surface", "empty": true},
    {"report": "cmp", "path": "transitions.repaired_with_test_change", "empty": true},
    {"report": "cmp", "path": "verification_surface.status", "eq": "reduced"},
    {"report": "cmp", "path": "outcome_verdict", "eq": "unchanged"}
  ]
}
